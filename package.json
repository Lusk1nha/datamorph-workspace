{
  "name": "datamorph-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "DataMorph Engine - Hybrid Node.js & Rust Architecture",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "rust:build": "cargo build --workspace",
    "rust:test": "cargo test --workspace",
    "rust:fmt": "cargo fmt --all"
  },
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.6"
  }
}
